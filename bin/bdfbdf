#!/usr/bin/env fontforge
# -*- mode: python; coding: utf-8 -*-

import os, sys, argparse
libdir = os.path.dirname(os.path.realpath(__file__)) + "/../lib"
sys.path.append(libdir)
from bdf_parser import BDFParser

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("filename")
    parser.add_argument("--use-properties", action="store_true")

    parser.add_argument('-x', '--resolution-x', '--res-x', '--x-resolution', '--x-res', type=int)
    parser.add_argument('-y', '--resolution-y', '--res-y', '--y-resolution', '--y-res', type=int)
    parser.add_argument('-f', '--font-name', '--ps-font-name')
    parser.add_argument('-m', '--family-name')
    parser.add_argument('-w', '--weight-name')
    parser.add_argument('-W', '--setwidth-name')
    parser.add_argument('-s', '--add-style-name', '--style-name')
    parser.add_argument('-F', '--full-name')

    args = parser.parse_args()
    bdf_parser = BDFParser(filename=args.filename, args=args)
    bdf_font = bdf_parser.font

    if args.resolution_x is not None:
        bdf_font.set_resolution_x(args.resolution_x)
    if args.resolution_y is not None:
        bdf_font.set_resolution_y(args.resolution_y)
    if args.font_name is not None:
        bdf_font.set_font_name(args.font_name)
    if args.family_name is not None:
        bdf_font.set_family_name(args.family_name)
    if args.weight_name is not None:
        bdf_font.set_weight_name(args.weight_name)
    if args.setwidth_name is not None:
        bdf_font.set_setwidth_name(args.setwidth_name)
    if args.add_style_name is not None:
        bdf_font.set_add_style_name(args.add_style_name)
    if args.full_name is not None:
        bdf_font.set_full_name(args.full_name)

    print(str(bdf_font))

    # bdfbdf (perl-font-bdf) compat:
    #   -x, --resolution-x, --res-x, --x-resolution, --x-res    int
    #   -y, --resolution-y, --res-y, --y-resolution, --y-res    int
    #   -f, --font-name, --ps-font-name                         str
    #   -m, --family-name                                       str
    #   -w, --weight-name                                       str
    #   -W, --setwidth-name                                     str
    #   -s, --style-name                                        str
    #   -F, --full-name                                         str
    #   -p, --property=name=value                               str
    #   --no-guess
    #   --guess-only
    #   --upper-case
    #   --lower-case
    #   --agl-names
    #   --dwidth-then-swidth
    #   --swidth-then-dwidth
    #   --verbose                                               incr
    #   --help

main()
